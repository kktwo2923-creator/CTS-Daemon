# 复制为 .env (本地) 或在 Koyeb/Render 后台逐项填入环境变量

# 数据库：本地自测用 SQLite 文件；生产用 Turso(持久、免费、免信用卡)
# 本地：
DATABASE_URL=file:local.db
# 生产(Turso)：把上面注释掉，改用下面两行(值从 Turso 控制台获取)
# DATABASE_URL=libsql://你的库名-用户名.turso.io
# DATABASE_AUTH_TOKEN=你的_turso_token

# 管理后台账号(首次初始化写入；之后改库或在后台改密码)
ADMIN_USER=admin
ADMIN_PASSWORD=请改成强密码

# 客户端 API 密钥(留空则首次初始化随机生成并在日志打印一次)
# API_KEY=SK_xxxxxxxxxxxxxxxx

# JWT 密钥(管理后台登录令牌签名)。生产务必设成 32+ 位随机串
JWT_SECRET=请用 openssl rand -hex 32 生成

# 卡密令牌签名密钥(服务端签发、守护端离线兜底校验用同一值)。务必设置并保密
LICENSE_SIGNING_SECRET=请用 openssl rand -hex 32 生成

# 端口(Koyeb/Render 会注入 PORT，本地默认 3000)
# PORT=3000
